{
  "name": "gay-guide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:smoke": "node scripts/test-smoke.mjs",
    "test:e2e-smoke": "node scripts/test-e2e-smoke.mjs",
    "test:regressions": "node scripts/test-regressions.mjs",
    "verify:release": "npm run lint && npm run test:smoke && npm run test:e2e-smoke && npm run test:regressions",
    "push:safe": "npm run verify:release && git push",
    "setup:githooks": "git config core.hooksPath .githooks",
    "backfill:place-locations": "node scripts/backfill-place-locations.mjs",
    "seed:city-reviews": "node scripts/seed-city-reviews.mjs"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.48.0",
    "@supabase/supabase-js": "^2.100.1",
    "@vercel/analytics": "^2.0.1",
    "lucide-react": "^1.7.0",
    "mapbox-gl": "^3.20.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4"
  },
  "engines": {
    "node": "22.x"
  },
  "browserslist": {
    "production": [
      "Chrome >= 111",
      "Edge >= 111",
      "Firefox >= 111",
      "Safari >= 16.4",
      "iOS >= 16.4",
      "Android >= 111"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
